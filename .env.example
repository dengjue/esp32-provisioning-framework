# Copy to .env and fill in your values (.env is gitignored)
# PlatformIO builds inject these as compile-time defines.

MQTT_BROKER=your.broker.ip
MQTT_PORT=1883
MQTT_TOPIC=your/topic
DEVICE_NAME=ESP32_LED

# Optional overrides (defaults in framework_config.h / app_config.h)
# DEVICE_TYPE=2
# LED_PIN=48
